{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "S4H_DRAFT_PROD",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/srv/(.*)$",
      "target": "/$1",
      "destination": "exchangerate-srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "localDir": "webapp",
      "authenticationType": "xsuaa"
    }
  ]
}