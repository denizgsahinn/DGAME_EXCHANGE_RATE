<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        id="valueHelpDialog"
        title="Seçim Yapın"
        items="{
            path: 'vh>/results'
        }"
        confirm=".onValueHelpConfirm"
        cancel=".onValueHelpCancel"
        search=".onValueHelpSearch">

        <StandardListItem
            title="{vh>key}"
            description="{vh>text}"
            type="Active" />

    </SelectDialog>

</core:FragmentDefinition>
